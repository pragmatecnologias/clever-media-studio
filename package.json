{
  "name": "clever-media-studio",
  "version": "1.0.0",
  "description": "Clever Campaign Studio — AI Media Assistant for Churches",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit --allowJs --checkJs --module esnext --target es2021 --moduleResolution bundler src/renderer/src/lib/configure-flow.mjs",
    "test": "node scripts/configure-flow-regression.mjs",
    "test:churchkit": "node scripts/churchkit-flow-regression.mjs",
    "test:all": "node scripts/configure-flow-regression.mjs && node scripts/churchkit-flow-regression.mjs",
    "preview": "electron-vite preview",
    "package": "electron-builder"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.5.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0"
  }
}
